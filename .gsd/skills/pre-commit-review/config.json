{
  "enabled": true,
  "autoFix": true,
  "severity": {
    "blockOnCritical": true,
    "blockOnHigh": false,
    "blockOnLow": false
  },
  "rules": {
    "xss": { 
      "enabled": true, 
      "autoFix": true,
      "patterns": [
        "innerHTML\\s*=",
        "\\.innerHTML\\s*\\+="
      ]
    },
    "injection": { 
      "enabled": true, 
      "autoFix": true,
      "patterns": [
        "JSON\\.parse.*localStorage",
        "JSON\\.parse.*sessionStorage",
        "JSON\\.parse.*data\\)"
      ]
    },
    "memoryLeaks": { 
      "enabled": true, 
      "autoFix": true,
      "patterns": [
        "setInterval",
        "setTimeout",
        "addEventListener"
      ]
    },
    "networkValidation": { 
      "enabled": true, 
      "autoFix": true,
      "patterns": [
        "\\.on\\('data'",
        "\\.on\\('message'",
        "as.*Packet"
      ]
    },
    "performance": { 
      "enabled": true, 
      "autoFix": false,
      "patterns": [
        "forEach.*forEach",
        "for.*for\\s*\\(",
        "requestAnimationFrame.*render"
      ]
    },
    "magicNumbers": { 
      "enabled": false, 
      "autoFix": false
    },
    "consoleStatements": { 
      "enabled": true, 
      "autoFix": true,
      "ignorePatterns": [
        "console\\.error",
        "console\\.warn"
      ]
    }
  },
  "skipTests": false,
  "requireBuildSuccess": false,
  "commitMessageTemplate": "{type}({scope}): {subject}",
  "dependencies": {
    "zod": "^3.22.4"
  }
}
